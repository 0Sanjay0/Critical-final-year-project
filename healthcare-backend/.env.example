# ─── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB Atlas ──────────────────────────────────────────
# Get this from: atlas.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/healthcare_db?retryWrites=true&w=majority

# ─── JWT ────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d

# ─── File Upload ─────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_BASE_PATH=./uploads

# ─── QR Codes ────────────────────────────────────────────────
QR_BASE_PATH=./qr

# ─── URLs (update after Render + Vercel deploy) ──────────────
# Your Render backend URL (no trailing slash)
SERVER_URL=https://YOUR_APP.onrender.com
# Your Vercel frontend URL (no trailing slash)
CLIENT_URL=https://YOUR_APP.vercel.app

# ─── Admin seed account ──────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=Admin@SecurePassword123
